{
  "name": "kospellcheck",
  "displayName": "KoSpellCheck",
  "description": "Offline HU+EN spell checker extension with code-aware tokenization and quick fix suggestions.",
  "version": "0.1.12",
  "publisher": "KoSpellCheckV2",
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:csharp",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onCommand:kospellcheck.addWordToProjectDictionary",
    "onCommand:kospellcheck.checkLocalTypoAccelerationStatus",
    "onCommand:kospellcheck.downloadLocalTypoRuntime"
  ],
  "main": "./out/extension.js",
  "files": [
    "out/**",
    "resources/**",
    "node_modules/nspell/**",
    "node_modules/is-buffer/**",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "contributes": {
    "commands": [
      {
        "command": "kospellcheck.addWordToProjectDictionary",
        "title": "KoSpellCheck: Add word to project dictionary"
      },
      {
        "command": "kospellcheck.checkLocalTypoAccelerationStatus",
        "title": "KoSpellCheck: Local Typo Accelerator állapot"
      },
      {
        "command": "kospellcheck.downloadLocalTypoRuntime",
        "title": "KoSpellCheck: Local Typo Runtime letöltése"
      }
    ],
    "configuration": {
      "title": "KoSpellCheck",
      "properties": {
        "kospellcheck.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable KoSpellCheck diagnostics."
        },
        "kospellcheck.debounceMs": {
          "type": "number",
          "default": 500,
          "description": "Debounce delay for document re-check."
        },
        "kospellcheck.debugLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose KoSpellCheck debug logs in Output panel."
        },
        "kospellcheck.localTypoAcceleration.mode": {
          "type": "string",
          "enum": [
            "off",
            "auto",
            "on"
          ],
          "default": "auto",
          "markdownDescription": "Opcionális helyi elírás-gyorsító mód. `auto`: csak akkor használja, ha kompatibilis helyi runtime + eszköz elérhető. `on`: mindig próbálja, de ha nem elérhető, automatikus fallback van. `off`: teljesen kikapcsolja ezt az útvonalat."
        },
        "kospellcheck.localTypoAcceleration.showDetectionPrompt": {
          "type": "boolean",
          "default": true,
          "description": "Egyszeri értesítést mutat, ha auto módban kompatibilis helyi gyorsító eszközt talál."
        },
        "kospellcheck.localTypoAcceleration.verboseLogging": {
          "type": "boolean",
          "default": false,
          "description": "Részletes naplózás a helyi elírás-gyorsító detektálásáról és döntéseiről."
        },
        "kospellcheck.localTypoAcceleration.autoDownloadRuntime": {
          "type": "boolean",
          "default": true,
          "description": "Automatikusan letölti a platformhoz tartozó Coral runtime csomagot a KoSpellCheck GitHub repóból (Coral-tpu/<Platform>) ha hiányzik."
        }
      }
    }
  },
  "scripts": {
    "prepare-assets": "node ./scripts/sync-assets.mjs",
    "build": "npm run prepare-assets && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext .ts",
    "test": "tsx --test src/test/**/*.test.ts",
    "package": "npm run build && npx vsce package --allow-missing-repository"
  },
  "dependencies": {
    "nspell": "^2.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/nspell": "^2.1.3",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vscode/vsce": "^3.6.2",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
